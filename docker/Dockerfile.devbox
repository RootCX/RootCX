FROM rust:1.88-bookworm AS cli-builder

WORKDIR /src
COPY Cargo.toml Cargo.lock BUN_VERSION ./
COPY core/ core/
COPY crates/ crates/
COPY runtime/client/ runtime/client/
RUN mkdir -p studio/src-tauri/src \
    && echo "fn main(){}" > studio/src-tauri/src/main.rs \
    && touch studio/src-tauri/src/lib.rs
COPY studio/src-tauri/Cargo.toml studio/src-tauri/Cargo.toml
RUN cargo build --release -p rootcx-cli

FROM node:22-bookworm-slim

ARG TARGETARCH
ARG BUN_VERSION=1.3.10
ARG ROOTCX_SKILLS_REV

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl fzf git ripgrep unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/rootcx/devbox
COPY docker/devbox/package.json docker/devbox/package-lock.json ./
RUN npm ci --omit=dev

COPY docker/devbox/runner.mjs ./runner.mjs
COPY docker/devbox/terminal.mjs ./terminal.mjs
COPY --from=cli-builder /src/target/release/rootcx /usr/local/bin/rootcx

RUN useradd --create-home --uid 10001 --shell /bin/bash devbox \
    && mkdir -p /workspace /home/devbox/.rootcx/bin /tmp/rootcx-skills \
    && cd /tmp/rootcx-skills \
    && echo "Installing RootCX skill revision ${ROOTCX_SKILLS_REV}" \
    && npx --yes skills add https://github.com/rootcx/skills --skill rootcx --agent claude-code --copy -y \
    && mkdir -p /opt/rootcx/skills \
    && mv .claude/skills/rootcx /opt/rootcx/skills/rootcx \
    && ln -s /opt/rootcx/devbox/node_modules/@anthropic-ai/claude-agent-sdk-linux-arm64/claude /usr/local/bin/claude \
    && rm -rf /tmp/rootcx-skills \
    && case "$TARGETARCH" in \
         arm64) BUN_TARGET="bun-linux-aarch64" ;; \
         *)     BUN_TARGET="bun-linux-x64" ;; \
       esac \
    && curl -fsSL "https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/${BUN_TARGET}.zip" -o /tmp/bun.zip \
    && unzip -q /tmp/bun.zip -d /tmp \
    && cp "/tmp/${BUN_TARGET}/bun" /home/devbox/.rootcx/bin/bun \
    && chmod +x /home/devbox/.rootcx/bin/bun /usr/local/bin/rootcx /usr/local/bin/claude \
    && chown -R devbox:devbox /workspace /home/devbox /opt/rootcx

ENV HOME=/home/devbox
ENV ROOTCX_WORKSPACE=/workspace
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

USER devbox
WORKDIR /workspace

ENTRYPOINT ["node", "/opt/rootcx/devbox/runner.mjs"]

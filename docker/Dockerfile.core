FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -r -s /bin/false -u 1001 rootcx-worker

COPY rootcx-core /usr/local/bin/rootcx-core
RUN chmod +x /usr/local/bin/rootcx-core

COPY core-entrypoint.sh /core-entrypoint.sh
RUN chmod +x /core-entrypoint.sh

RUN mkdir -p /data && chown root:root /data

EXPOSE 9100

ENTRYPOINT ["/core-entrypoint.sh"]
CMD ["rootcx-core", "--daemon"]

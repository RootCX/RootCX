{
  "appId": "bi",
  "name": "BI",
  "version": "0.1.0",
  "description": "BI lets you ask questions over installed apps data and design visualizations and dashboards.",
  "permissions": [
    { "name": "bi.query.create", "description": "Create saved queries", "category": "write" },
    { "name": "bi.query.read", "description": "View saved queries", "category": "read" },
    { "name": "bi.query.update", "description": "Update saved queries", "category": "write" },
    { "name": "bi.query.delete", "description": "Delete saved queries", "category": "delete" },

    { "name": "bi.dashboard.create", "description": "Create dashboards", "category": "write" },
    { "name": "bi.dashboard.read", "description": "View dashboards", "category": "read" },
    { "name": "bi.dashboard.update", "description": "Update dashboards", "category": "write" },
    { "name": "bi.dashboard.delete", "description": "Delete dashboards", "category": "delete" }
  ],
  "dataContract": [
    {
      "entityName": "saved_query",
      "fields": [
        {
          "id": "query_name",
          "name": "name",
          "label": "Name",
          "type": "text",
          "required": true
        },
        {
          "id": "query_description",
          "name": "description",
          "label": "Description",
          "type": "text",
          "required": false
        },
        {
          "id": "query_prompt",
          "name": "prompt",
          "label": "User Prompt",
          "type": "text",
          "required": true
        },
        {
          "id": "query_sql",
          "name": "generated_sql",
          "label": "Generated SQL",
          "type": "text",
          "required": true
        },
        {
          "id": "query_viz_type",
          "name": "visualization_type",
          "label": "Visualization Type",
          "type": "text",
          "required": true
        },
        {
          "id": "query_viz_config",
          "name": "visualization_config",
          "label": "Visualization Config",
          "type": "json",
          "required": false,
          "defaultValue": {}
        },
        {
          "id": "query_last_run_at",
          "name": "last_run_at",
          "label": "Last Run At",
          "type": "datetime",
          "required": false
        },
        {
          "id": "query_tags",
          "name": "tags",
          "label": "Tags",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "entityName": "dashboard",
      "fields": [
        {
          "id": "dashboard_name",
          "name": "name",
          "label": "Name",
          "type": "text",
          "required": true
        },
        {
          "id": "dashboard_description",
          "name": "description",
          "label": "Description",
          "type": "text",
          "required": false
        },
        {
          "id": "dashboard_layout_config",
          "name": "layout_config",
          "label": "Layout Config",
          "type": "json",
          "required": false,
          "defaultValue": { "cols": 12, "rowHeight": 100 }
        },
        {
          "id": "dashboard_is_favorite",
          "name": "is_favorite",
          "label": "Favorite",
          "type": "boolean",
          "required": false,
          "defaultValue": false
        }
      ]
    },
    {
      "entityName": "dashboard_widget",
      "fields": [
        {
          "id": "widget_dashboard_id",
          "name": "dashboard_id",
          "label": "Dashboard",
          "type": "entity_link",
          "required": true,
          "references": {
            "entity": "dashboard",
            "field": "id"
          },
          "relationshipType": "many-to-one"
        },
        {
          "id": "widget_query_id",
          "name": "saved_query_id",
          "label": "Saved Query",
          "type": "entity_link",
          "required": true,
          "references": {
            "entity": "saved_query",
            "field": "id"
          },
          "relationshipType": "many-to-one"
        },
        {
          "id": "widget_position_x",
          "name": "position_x",
          "label": "Position X",
          "type": "number",
          "required": true,
          "defaultValue": 0
        },
        {
          "id": "widget_position_y",
          "name": "position_y",
          "label": "Position Y",
          "type": "number",
          "required": true,
          "defaultValue": 0
        },
        {
          "id": "widget_width",
          "name": "width",
          "label": "Width",
          "type": "number",
          "required": true,
          "defaultValue": 6
        },
        {
          "id": "widget_height",
          "name": "height",
          "label": "Height",
          "type": "number",
          "required": true,
          "defaultValue": 4
        },
        {
          "id": "widget_refresh_interval",
          "name": "refresh_interval_seconds",
          "label": "Refresh Interval (seconds)",
          "type": "number",
          "required": false
        }
      ]
    }
  ]
}

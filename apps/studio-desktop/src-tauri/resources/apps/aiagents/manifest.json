{
  "appId": "aiagents",
  "name": "AI Agents",
  "version": "0.0.1",
  "description": "Chat with AI agents in your organization. Mention agents with @ to get instant intelligent assistance with your work. Agents can help automate tasks, answer questions, and collaborate across your tools and data.",
  "routes": [
    {
      "path": "/conversations",
      "label": "Conversations",
      "description": "List of all AI conversations"
    },
    {
      "path": "/conversations/:conversationId",
      "label": "Chat",
      "entity": "conversation",
      "description": "View a specific conversation"
    },
    {
      "path": "/settings",
      "label": "Settings",
      "description": "AI Agents settings"
    }
  ],
  "permissions": [
    {
      "name": "aiagents.conversation.create",
      "description": "Create conversations",
      "category": "write"
    },
    {
      "name": "aiagents.conversation.read",
      "description": "View conversations",
      "category": "read"
    },
    {
      "name": "aiagents.conversation.update",
      "description": "Edit conversations",
      "category": "write"
    },
    {
      "name": "aiagents.conversation.delete",
      "description": "Delete conversations",
      "category": "delete"
    },
    {
      "name": "aiagents.message.create",
      "description": "Send messages",
      "category": "write"
    },
    {
      "name": "aiagents.message.read",
      "description": "Read messages",
      "category": "read"
    },
    {
      "name": "aiagents.message.update",
      "description": "Edit messages",
      "category": "write"
    },
    {
      "name": "aiagents.message.delete",
      "description": "Delete messages",
      "category": "delete"
    }
  ],
  "dataContract": [
    {
      "entityName": "conversation",
      "fields": [
        {
          "id": "conversation_name",
          "name": "name",
          "label": "Name",
          "type": "text",
          "required": true,
          "description": "Conversation title"
        },
        {
          "id": "conversation_created_by",
          "name": "created_by",
          "label": "Created By",
          "type": "entity_link",
          "required": true,
          "description": "User who created the conversation",
          "references": {
            "entity": "system.organization_members",
            "field": "user_id"
          }
        },
        {
          "id": "conversation_created_at",
          "name": "created_at",
          "label": "Created At",
          "type": "timestamp",
          "required": true,
          "description": "When the conversation was created"
        },
        {
          "id": "conversation_updated_at",
          "name": "updated_at",
          "label": "Updated At",
          "type": "timestamp",
          "required": true,
          "description": "When the conversation was last updated"
        }
      ]
    },
    {
      "entityName": "message",
      "fields": [
        {
          "id": "message_content",
          "name": "content",
          "label": "Content",
          "type": "text",
          "required": true,
          "description": "Message content with @mentions"
        },
        {
          "id": "message_conversation_id",
          "name": "conversation_id",
          "label": "Conversation",
          "type": "entity_link",
          "required": true,
          "description": "Conversation this message belongs to",
          "references": {
            "entity": "conversation",
            "field": "id"
          }
        },
        {
          "id": "message_sender_type",
          "name": "sender_type",
          "label": "Sender Type",
          "type": "text",
          "required": true,
          "description": "Who sent the message",
          "validation": {
            "enum": [
              "user",
              "agent"
            ]
          },
          "defaultValue": "user"
        },
        {
          "id": "message_agent_id",
          "name": "agent_id",
          "label": "Agent ID",
          "type": "text",
          "required": false,
          "description": "ID of AI agent if sender is an agent"
        },
        {
          "id": "message_mentions",
          "name": "mentions",
          "label": "Mentions",
          "type": "text",
          "required": false,
          "description": "JSON array of mentioned agent IDs"
        },
        {
          "id": "message_user_id",
          "name": "user_id",
          "label": "User",
          "type": "entity_link",
          "required": true,
          "description": "User who sent the message",
          "references": {
            "entity": "system.organization_members",
            "field": "user_id"
          }
        },
        {
          "id": "message_created_at",
          "name": "created_at",
          "label": "Created At",
          "type": "timestamp",
          "required": true,
          "description": "When the message was sent"
        },
        {
          "id": "message_updated_at",
          "name": "updated_at",
          "label": "Updated At",
          "type": "timestamp",
          "required": true,
          "description": "When the message was last updated"
        },
        {
          "id": "message_attachment",
          "name": "attachment",
          "label": "Attachment",
          "type": "file",
          "required": false,
          "description": "Optional file attachment (CSV, text, image)"
        }
      ]
    },
    {
      "entityName": "checkpoint",
      "fields": [
        {
          "id": "checkpoint_thread_id",
          "name": "thread_id",
          "label": "Thread ID",
          "type": "text",
          "required": true,
          "description": "Thread identifier (conversation ID)"
        },
        {
          "id": "checkpoint_checkpoint_ns",
          "name": "checkpoint_ns",
          "label": "Checkpoint Namespace",
          "type": "text",
          "required": true,
          "description": "Checkpoint namespace for isolation",
          "defaultValue": ""
        },
        {
          "id": "checkpoint_checkpoint_id",
          "name": "checkpoint_id",
          "label": "Checkpoint ID",
          "type": "text",
          "required": true,
          "description": "Unique checkpoint identifier (uuid)"
        },
        {
          "id": "checkpoint_parent_checkpoint_id",
          "name": "parent_checkpoint_id",
          "label": "Parent Checkpoint ID",
          "type": "text",
          "required": false,
          "description": "Parent checkpoint ID for history chain"
        },
        {
          "id": "checkpoint_type",
          "name": "type",
          "label": "Type",
          "type": "text",
          "required": false,
          "description": "Checkpoint type"
        },
        {
          "id": "checkpoint_data",
          "name": "checkpoint_data",
          "label": "Checkpoint Data",
          "type": "text",
          "required": true,
          "description": "Serialized checkpoint state (JSON)"
        },
        {
          "id": "checkpoint_metadata",
          "name": "metadata",
          "label": "Metadata",
          "type": "text",
          "required": false,
          "description": "Checkpoint metadata (JSON)"
        }
      ]
    },
    {
      "entityName": "checkpoint_writes",
      "fields": [
        {
          "id": "cw_thread_id",
          "name": "thread_id",
          "label": "Thread ID",
          "type": "text",
          "required": true,
          "description": "Thread identifier"
        },
        {
          "id": "cw_checkpoint_ns",
          "name": "checkpoint_ns",
          "label": "Checkpoint Namespace",
          "type": "text",
          "required": true,
          "description": "Checkpoint namespace",
          "defaultValue": ""
        },
        {
          "id": "cw_checkpoint_id",
          "name": "checkpoint_id",
          "label": "Checkpoint ID",
          "type": "text",
          "required": true,
          "description": "Associated checkpoint ID"
        },
        {
          "id": "cw_task_id",
          "name": "task_id",
          "label": "Task ID",
          "type": "text",
          "required": true,
          "description": "Task identifier for this write"
        },
        {
          "id": "cw_idx",
          "name": "idx",
          "label": "Index",
          "type": "number",
          "required": true,
          "description": "Write index for ordering"
        },
        {
          "id": "cw_channel",
          "name": "channel",
          "label": "Channel",
          "type": "text",
          "required": true,
          "description": "State channel name"
        },
        {
          "id": "cw_type",
          "name": "type",
          "label": "Type",
          "type": "text",
          "required": false,
          "description": "Write type"
        },
        {
          "id": "cw_value",
          "name": "value",
          "label": "Value",
          "type": "text",
          "required": true,
          "description": "Serialized write value (JSON)"
        }
      ]
    }
  ]
}
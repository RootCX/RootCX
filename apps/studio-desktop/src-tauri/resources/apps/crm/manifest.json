{
  "appId": "crm",
  "name": "CRM",
  "version": "0.0.1",
  "description": "Close more deals with a CRM that keeps everything connected natively. RootCX gives Sales teams a single customer record where emails, calls, meetings, and contracts stay in sync by design. Never miss a timeline, keep momentum in every deal, and stay proactive with clear visibility at each stage. Faster sales cycles, reliable follow-ups, and reporting you can trust, this is the next-gen CRM built for teams who want to sell, not reconcile data.",
  "routes": [
    {
      "path": "/contacts",
      "label": "Contacts",
      "description": "List of all contacts"
    },
    {
      "path": "/contacts/:contactId",
      "label": "Contact Details",
      "entity": "user",
      "description": "View a specific contact"
    },
    {
      "path": "/contacts/:contactId/notes",
      "label": "Contact Notes",
      "description": "Notes for a contact"
    },
    {
      "path": "/contacts/:contactId/notes/:noteId",
      "label": "Note Details",
      "entity": "note",
      "description": "View a specific note"
    },
    {
      "path": "/companies",
      "label": "Companies",
      "description": "List of all companies"
    },
    {
      "path": "/companies/:companyId",
      "label": "Company Details",
      "entity": "company",
      "description": "View a specific company"
    },
    {
      "path": "/companies/:companyId/notes",
      "label": "Company Notes",
      "description": "Notes for a company"
    },
    {
      "path": "/companies/:companyId/notes/:noteId",
      "label": "Note Details",
      "entity": "note",
      "description": "View a specific note"
    },
    {
      "path": "/deals",
      "label": "Deals",
      "description": "List of all deals"
    },
    {
      "path": "/deals/:id",
      "label": "Deal Details",
      "entity": "deal",
      "description": "View a specific deal"
    },
    {
      "path": "/settings/:section",
      "label": "Settings",
      "description": "CRM settings"
    }
  ],

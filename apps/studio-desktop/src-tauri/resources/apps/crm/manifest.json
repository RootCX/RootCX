  "dataContract": [
    {
      "entityName": "user",
      "displayName": "Contacts",
      "coreEntity": "User",
      "recordLabelField": "first_name",
      "fields": [
        {
          "id": "user_first_name",
          "name": "first_name",
          "label": "First Name",
          "type": "text",
          "required": true,
          "description": "User first name"
        },
        {
          "id": "user_last_name",
          "name": "last_name",
          "label": "Last Name",
          "type": "text",
          "required": true,
          "description": "User last name"
        },
        {
          "id": "user_email",
          "name": "email",
          "label": "Email Address",
          "type": "text",
          "required": false,
          "description": "Primary email address (from global users table)",
          "validation": {
            "pattern": "^[^@]+@[^@]+\\.[^@]+$"
          }
        },
        {
          "id": "user_phone",
          "name": "phone",
          "label": "Phone Numbers",
          "type": "[text]",
          "required": false,
          "description": "Phone numbers (multiple allowed)"
        },
        {
          "id": "user_company_id",
          "name": "company_id",
          "label": "Primary Company",
          "type": "entity_link",
          "relationshipType": "many_to_one",
          "required": false,
          "description": "Primary company this contact belongs to",
          "references": {
            "entity": "company",
            "field": "id"
          }
        },
        {
          "id": "user_source",
          "name": "source",
          "label": "User Source",
          "type": "text",
          "required": false,
          "description": "How the user was imported/created",
          "validation": {
            "enum": [
              "manual",
              "import",
              "api",
              "virtual_models",
              "web",
              "referral"
            ]
          }
        },
        {
          "id": "crm_lifecycle_stage",
          "name": "lifecycle_stage",
          "label": "Lifecycle Stage",
          "type": "text",
          "required": false,
          "description": "Current lifecycle stage in CRM",
          "validation": {
            "enum": [
              "lead",
              "opportunity",
              "client"
            ]
          }
        },
        {
          "id": "crm_score",
          "name": "score",
          "label": "CRM Score",
          "type": "number",
          "required": false,
          "description": "CRM lead/customer score (0-100)",
          "validation": {
            "min": 0,
            "max": 100
          }
        },
        {
          "id": "user_created_at",
          "name": "created_at",
          "label": "Created At",
          "type": "timestamp",
          "required": true,
          "description": "User creation timestamp"
        },
        {
          "id": "user_updated_at",
          "name": "updated_at",
          "label": "Updated At",
          "type": "timestamp",
          "required": true,
          "description": "Last update timestamp"
        }
      ]
    },

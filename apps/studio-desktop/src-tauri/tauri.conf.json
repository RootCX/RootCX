{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "RootCX Studio",
  "version": "0.1.0",
  "identifier": "com.rootcx.studio",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../apps/studio-ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../../apps/studio-ui build",
    "frontendDist": "../../apps/studio-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "RootCX Studio",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/pg/**/*": "resources/pg/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

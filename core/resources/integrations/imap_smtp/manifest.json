{
  "appId": "imap_smtp",
  "name": "IMAP / SMTP",
  "version": "0.3.0",
  "type": "integration",
  "description": "Email integration via generic IMAP/SMTP. Owns email data with per-user sync. Consumer apps read via the collections API.",
  "crons": [{
    "name": "sync",
    "schedule": "*/5 * * * *",
    "payload": { "type": "sync_all" }
  }],
  "configSchema": {
    "type": "object",
    "properties": {}
  },
  "userAuth": {
    "type": "credentials",
    "schema": {
      "type": "object",
      "properties": {
        "imapHost": { "type": "string", "description": "IMAP server hostname", "label": "IMAP Host", "placeholder": "imap.example.com" },
        "imapPort": { "type": "integer", "description": "IMAP port (993 for TLS)", "label": "IMAP Port", "default": 993 },
        "smtpHost": { "type": "string", "description": "SMTP server hostname", "label": "SMTP Host", "placeholder": "smtp.example.com" },
        "username": { "type": "string", "description": "Email address or username", "label": "Email / Username", "placeholder": "you@example.com" },
        "password": { "type": "string", "description": "Password or app-specific password", "label": "Password", "secret": true }
      },
      "required": ["username", "password", "imapHost", "smtpHost"]
    }
  },
  "actions": [
    {
      "id": "send_email",
      "name": "Send Email",
      "description": "Send via SMTP, append to Sent folder, auto-persist in imap_smtp.messages.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "to": { "type": "string" },
          "subject": { "type": "string" },
          "body": { "type": "string" },
          "cc": { "type": "string" },
          "bcc": { "type": "string" },
          "html": { "type": "boolean", "default": false }
        },
        "required": ["to", "subject", "body"]
      },
      "outputSchema": { "type": "object", "properties": { "messageId": { "type": "string" }, "ok": { "type": "boolean" } } }
    },
    {
      "id": "get_email",
      "name": "Get Email",
      "description": "Fetch and parse a single email by UID + folder.",
      "inputSchema": { "type": "object", "properties": { "uid": { "type": "integer" }, "folder": { "type": "string", "default": "INBOX" } }, "required": ["uid"] },
      "outputSchema": { "type": "object" }
    },
    {
      "id": "list_emails",
      "name": "List Emails",
      "description": "List message UIDs from a folder. Use sinceUid for incremental sync.",
      "inputSchema": { "type": "object", "properties": { "folder": { "type": "string", "default": "INBOX" }, "sinceUid": { "type": "integer" } } },
      "outputSchema": { "type": "object", "properties": { "messageUids": { "type": "array" }, "uidValidity": { "type": "integer" }, "highestUid": { "type": "integer" } } }
    },
    {
      "id": "get_folders",
      "name": "Get Folders",
      "description": "List all IMAP folders with special-use flags.",
      "inputSchema": { "type": "object" },
      "outputSchema": { "type": "object" }
    },
    {
      "id": "sync_connect",
      "name": "Start Sync",
      "description": "Initialize sync for the current user. Creates a sync_cursor and triggers the first sync.",
      "inputSchema": { "type": "object" },
      "outputSchema": { "type": "object", "properties": { "cursor_id": { "type": "string" }, "handle": { "type": "string" } } }
    },
    {
      "id": "sync_disconnect",
      "name": "Stop Sync",
      "description": "Disable sync for the current user. Keeps synced data.",
      "inputSchema": { "type": "object" },
      "outputSchema": { "type": "object" }
    },
    {
      "id": "sync_now",
      "name": "Trigger Sync",
      "description": "Trigger an immediate sync for the current user.",
      "inputSchema": { "type": "object" },
      "outputSchema": { "type": "object", "properties": { "triggered": { "type": "boolean" } } }
    }
  ],
  "webhooks": [],
  "dataContract": [
    {
      "entityName": "messages",
      "fields": [
        { "name": "external_id",        "type": "text", "unique": true },
        { "name": "thread_external_id",  "type": "text" },
        { "name": "header_message_id",   "type": "text", "unique": true },
        { "name": "user_id",            "type": "text", "required": true },
        { "name": "folder",             "type": "text" },
        { "name": "subject",            "type": "text" },
        { "name": "body_text",          "type": "text" },
        { "name": "body_html",          "type": "text" },
        { "name": "snippet",            "type": "text" },
        { "name": "internal_date",      "type": "timestamp" },
        { "name": "flags",              "type": "text" },
        { "name": "in_reply_to",        "type": "text" },
        { "name": "references",         "type": "text" }
      ]
    },
    {
      "entityName": "threads",
      "fields": [
        { "name": "external_id",        "type": "text", "unique": true },
        { "name": "user_id",            "type": "text", "required": true },
        { "name": "subject",            "type": "text" },
        { "name": "last_message_at",    "type": "timestamp" },
        { "name": "message_count",      "type": "number" }
      ]
    },
    {
      "entityName": "participants",
      "fields": [
        { "name": "message_id",  "type": "entity_link", "onDelete": "cascade", "references": { "entity": "messages", "field": "id" }, "required": true },
        { "name": "address",     "type": "text", "required": true },
        { "name": "name",        "type": "text" },
        { "name": "role",        "type": "text", "required": true, "enum_values": ["from", "to", "cc", "bcc"] }
      ]
    },
    {
      "entityName": "attachments",
      "fields": [
        { "name": "message_id",   "type": "entity_link", "onDelete": "cascade", "references": { "entity": "messages", "field": "id" }, "required": true },
        { "name": "filename",     "type": "text" },
        { "name": "mime_type",    "type": "text" },
        { "name": "size",         "type": "number" },
        { "name": "content_id",   "type": "text" },
        { "name": "is_inline",    "type": "boolean" }
      ]
    },
    {
      "entityName": "sync_cursors",
      "fields": [
        { "name": "user_id",          "type": "text", "required": true },
        { "name": "connection_id",    "type": "text" },
        { "name": "handle",           "type": "text" },
        { "name": "cursor",           "type": "text" },
        { "name": "status",           "type": "text", "enum_values": ["idle", "syncing", "needs_reauth", "failed_temporary", "failed_permanent"] },
        { "name": "last_synced_at",   "type": "timestamp" },
        { "name": "throttle_count",   "type": "number" },
        { "name": "throttle_after",   "type": "timestamp" },
        { "name": "cron_id",          "type": "text" },
        { "name": "enabled",          "type": "boolean" }
      ]
    }
  ],
  "permissions": {
    "permissions": [
      { "key": "messages.read",      "description": "Read synced emails" },
      { "key": "messages.write",     "description": "Write emails (internal sync)" },
      { "key": "threads.read",       "description": "Read email threads" },
      { "key": "threads.write",      "description": "Write threads (internal sync)" },
      { "key": "participants.read",  "description": "Read email participants" },
      { "key": "participants.write", "description": "Write participants (internal sync)" },
      { "key": "attachments.read",   "description": "Read attachment metadata" },
      { "key": "attachments.write",  "description": "Write attachments (internal sync)" },
      { "key": "sync_cursors.read",  "description": "Read sync state" },
      { "key": "sync_cursors.write", "description": "Manage sync state" }
    ]
  },
  "instructions": "IMAP/SMTP integration v1.0 -- owns email data.\n\nSyncs emails from connected IMAP accounts and stores them in its own entities. Consumer apps read via collections API:\n\n  GET /api/v1/apps/imap_smtp/collections/messages?where={...}\n  GET /api/v1/apps/imap_smtp/collections/participants?where={address: {$eq: \"user@example.com\"}}\n\nSync lifecycle:\n- `sync_connect` initializes sync + creates a 5-min cron\n- `sync_disconnect` stops the cron\n- `sync_now` triggers immediate sync\n\nSync uses UID-based incremental: stores (folder, highestUid, uidValidity) per folder. If uidValidity changes, full resync of that folder.\n\nSend via `send_email` (SMTP) -- auto-persists the sent message.\n\nCommon server configs:\n- Gmail: imap.gmail.com:993, smtp.gmail.com (requires app password)\n- Outlook: outlook.office365.com:993, smtp.office365.com:587\n- Yahoo: imap.mail.yahoo.com:993, smtp.mail.yahoo.com\n- Fastmail: imap.fastmail.com:993, smtp.fastmail.com"
}

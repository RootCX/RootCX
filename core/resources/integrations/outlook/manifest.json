{
  "appId": "outlook",
  "name": "Outlook",
  "version": "0.1.0",
  "type": "integration",
  "description": "Send, read and manage emails via Microsoft Graph API (Outlook)",
  "configSchema": {
    "type": "object",
    "properties": {
      "clientId": { "type": "string", "description": "Microsoft Entra App (client) ID", "platformSecret": "OUTLOOK_CLIENT_ID" },
      "clientSecret": { "type": "string", "description": "Microsoft Entra Client Secret", "platformSecret": "OUTLOOK_CLIENT_SECRET" },
      "proxyToken": { "type": "string", "description": "Managed proxy HMAC token (managed mode only)", "platformSecret": "OUTLOOK_PROXY_TOKEN" },
      "baseUrl": { "type": "string", "description": "Managed proxy base URL (managed mode only)", "platformSecret": "OUTLOOK_BASE_URL" }
    }
  },
  "userAuth": { "type": "redirect" },
  "actions": [
    {
      "id": "send_email",
      "name": "Send Email",
      "description": "Send an email via Outlook",
      "inputSchema": {
        "type": "object",
        "properties": {
          "to": { "type": "string" },
          "subject": { "type": "string" },
          "body": { "type": "string" },
          "cc": { "type": "string" },
          "bcc": { "type": "string" },
          "html": { "type": "boolean", "default": false },
          "saveToSentItems": { "type": "boolean", "default": true }
        },
        "required": ["to", "subject", "body"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" }
        }
      }
    },
    {
      "id": "list_emails",
      "name": "List Emails",
      "description": "List recent emails from a mail folder",
      "inputSchema": {
        "type": "object",
        "properties": {
          "folder": { "type": "string", "description": "Mail folder name or ID (default: Inbox)", "default": "Inbox" },
          "top": { "type": "integer", "description": "Number of messages to return (max 1000)", "default": 10 },
          "filter": { "type": "string", "description": "OData $filter expression (e.g. \"isRead eq false\")" },
          "search": { "type": "string", "description": "Search query (KQL syntax, e.g. \"from:user@example.com\")" }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "conversationId": { "type": "string" },
                "subject": { "type": "string" },
                "from": { "type": "string" },
                "receivedDateTime": { "type": "string" },
                "isRead": { "type": "boolean" },
                "bodyPreview": { "type": "string" }
              }
            }
          },
          "nextLink": { "type": "string", "description": "@odata.nextLink for pagination" }
        }
      }
    },
    {
      "id": "get_email",
      "name": "Get Email",
      "description": "Get full email by message ID",
      "inputSchema": {
        "type": "object",
        "properties": { "messageId": { "type": "string" } },
        "required": ["messageId"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "conversationId": { "type": "string" },
          "subject": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "array", "items": { "type": "string" } },
          "cc": { "type": "array", "items": { "type": "string" } },
          "receivedDateTime": { "type": "string" },
          "isRead": { "type": "boolean" },
          "importance": { "type": "string" },
          "hasAttachments": { "type": "boolean" },
          "bodyPreview": { "type": "string" },
          "body": { "type": "string", "description": "HTML or plain text body" },
          "flag": { "type": "object" }
        }
      }
    },
    {
      "id": "modify_email",
      "name": "Modify Email",
      "description": "Update message properties (read status, flag, importance, categories)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "messageId": { "type": "string" },
          "isRead": { "type": "boolean" },
          "flag": { "type": "string", "enum": ["flagged", "notFlagged", "complete"] },
          "importance": { "type": "string", "enum": ["low", "normal", "high"] },
          "categories": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["messageId"]
      },
      "outputSchema": {
        "type": "object",
        "properties": { "ok": { "type": "boolean" } }
      }
    }
    },
    {
      "id": "batch_get_emails",
      "name": "Batch Get Emails",
      "description": "Get multiple emails by message IDs in batch (max 20 per sub-batch, auto-chunked)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "messageIds": { "type": "array", "items": { "type": "string" }, "description": "Array of message IDs to fetch" }
        },
        "required": ["messageIds"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "messages": { "type": "array", "items": { "type": "object" } }
        }
      }
    },
    {
      "id": "delta_list",
      "name": "Delta List",
      "description": "Get incremental changes (added/deleted messages) using MS Graph delta. First call without deltaLink for full sync, subsequent calls with deltaLink for incremental.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "deltaLink": { "type": "string", "description": "Delta link from previous call (omit for first sync)" },
          "folder": { "type": "string", "description": "Mail folder (default: Inbox)", "default": "Inbox" },
          "top": { "type": "integer", "description": "Page size", "default": 100 }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "messagesAdded": { "type": "array", "items": { "type": "string" } },
          "messagesDeleted": { "type": "array", "items": { "type": "string" } },
          "nextLink": { "type": "string", "description": "Next page link (null if done)" },
          "deltaLink": { "type": "string", "description": "Delta link for next incremental sync (only present on last page)" }
        }
      }
    }
  ],
  "webhooks": ["mail_notification"],
  "instructions": "Outlook integration with OAuth 2.0 per-user auth via Microsoft Entra ID (Azure AD).\n\n`list_emails` returns a summary of messages (id, subject, from, receivedDateTime, isRead, bodyPreview, internetMessageId). Use `get_email` for full body content.\n\nThe `folder` param defaults to \"Inbox\". Other well-known folder names: Drafts, SentItems, DeletedItems, Junk, Archive.\n\n`batch_get_emails` fetches multiple messages by ID using MS Graph JSON batching (20/batch, auto-chunked). Returns normalized format compatible with Gmail batch_get_emails (headerMessageId, from, to, cc, date, body, threadId, labelIds).\n\n`delta_list` provides incremental sync via MS Graph delta query. First call without deltaLink returns all message IDs. Subsequent calls with the returned deltaLink return only changes. Delta links are long-lived (~30 days). Returns messagesAdded and messagesDeleted arrays.\n\n`get_email` returns body as plain text (via Prefer header). No client-side HTML conversion needed.\n\nOData `$filter` and KQL `$search` supported in `list_emails`.\n\n`modify_email` can update: isRead, flag, importance, categories.",
  "entities": []
}

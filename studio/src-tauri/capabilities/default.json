{
  "identifier": "default",
  "description": "Default capabilities for RootCX Studio",
  "windows": ["main", "studio-*"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "log:default",
    "updater:default",
    "process:allow-restart"
  ]
}
